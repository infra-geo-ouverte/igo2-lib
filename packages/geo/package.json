{
  "name": "@igo2/geo",
  "version": "21.0.0-next.1",
  "description": "IGO Library",
  "author": "IGO Community",
  "keywords": [
    "igo"
  ],
  "license": "MIT",
  "homepage": "https://github.com/infra-geo-ouverte/igo2-lib#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infra-geo-ouverte/igo2-lib.git",
    "directory": "packages/geo"
  },
  "bugs": {
    "url": "https://github.com/infra-geo-ouverte/igo2-lib/issues"
  },
  "scripts": {
    "build": "ng build geo --configuration production",
    "postbuild": "node --import tsx ../../scripts/src/geo/postbuild-geo.mts",
    "format": "prettier --write ./src/**/*.{ts,js,html,scss,css,json}",
    "lint": "ng lint geo",
    "lint.fix": "ng lint geo --fix",
    "test": "ng test geo --watch=false",
    "test.watch": "ng test geo",
    "watch": "ng build geo --watch"
  },
  "exports": {
    ".": {
      "sass": "./src/_index.scss",
      "import": "./src/public_api.ts"
    },
    "./style": {
      "sass": "./style/style.scss"
    }
  },
  "dependencies": {
    "tslib": "^2.8.0"
  },
  "peerDependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/material-moment-adapter": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@igo2/auth": "*",
    "@igo2/common": "*",
    "@igo2/core": "*",
    "@igo2/utils": "*",
    "@geostyler/web-component": "*",
    "@mat-datetimepicker/core": "^17.0.0",
    "geostyler-legend": "^5.2.0",
    "geostyler-openlayers-parser": "^5.7.0",
    "@turf/boolean-intersects": "^7.3.0",
    "@turf/buffer": "^7.3.0",
    "@turf/helpers": "^7.3.0",
    "@turf/intersect": "^7.3.0",
    "@turf/line-intersect": "^7.3.0",
    "@turf/point-on-feature": "^7.3.0",
    "file-saver": "^2.0.2",
    "flexsearch": "0.7.21",
    "html2canvas": "^1.4.0",
    "idb": "^8.0.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.0",
    "jszip": "^3.10.0",
    "moment": "^2.30.0",
    "nosleep.js": "^0.12.0",
    "ol-mapbox-style": "^13.1.0",
    "ol": "^10.9.0",
    "proj4": "^2.20.0",
    "rxjs": "^7.8.0",
    "striptags": "^3.2.0",
    "ts-cacheable": "^1.0.0",
    "ts-md5": "^2.0.0"
  },
  "engines": {
    "node": "^18.19.1 || ^20.11.1 || >=22.0.0"
  },
  "": {
    "canvg": "Is install for JSPDF installation error",
    "dompurify": "Is install for JSPDF installation error"
  }
