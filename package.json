{
  "name": "igo2-lib",
  "workspaces": [
    "packages/*",
    "projects/*"
  ],
  "version": "21.0.0-next.6",
  "description": "IGO Library",
  "author": "IGO Community",
  "license": "MIT",
  "homepage": "https://github.com/infra-geo-ouverte/igo2-lib#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infra-geo-ouverte/igo2-lib.git"
  },
  "bugs": {
    "url": "https://github.com/infra-geo-ouverte/igo2-lib/issues"
  },
  "engines": {
    "node": ">=18.13.0"
  },
  "scripts": {
    "ng": "ng",
    "postinstall": "git config core.hooksPath .config/git-hooks",
    "prestart": "npm run prestart --workspace=packages --if-present",
    "start.demo": "npm run prestart && npm run start -w demo",
    "build": "ng build",
    "build.demo": "npm run build -w demo",
    "build.libs": "node --import tsx scripts/src/build-library.mts",
    "build.doc": "compodoc -p tsconfig.json --disablePrivate --disableProtected --disableInternal --disableLifeCycleHooks --theme material",
    "format.check": "prettier packages projects scripts --check --config .prettierrc",
    "format": "prettier --write packages projects scripts --check --config .prettierrc",
    "format.scripts": "prettier --write ./scripts/src/**/*.{mts,ts,js,json}",
    "lint": "ng lint --quiet",
    "lint.fix": "ng lint --fix --quiet",
    "types": "npm run types --workspaces --if-present",
    "doc": "npm run build.doc && compodoc -s --port 4220",
    "test": "ng test --watch=false",
    "test.ci": "ng test --watch=false --browsers=ChromiumHeadless",
    "test.libs": "npm run test --workspace=packages",
    "compodoc": "npx compodoc -p tsconfig.json",
    "circular-deps": "madge --circular --extensions ts packages"
  },
  "dependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/material": "^21.2.8",
    "@angular/platform-browser": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@igo2/sdg-core": "2.0.0-next.2",
    "core-js": "^3.32.2",
    "jspdf": "^4.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.10",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/format": "^20.0.0",
    "@commitlint/types": "^20.0.0",
    "@compodoc/compodoc": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^12.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/geojson": "^7946.0.0",
    "@types/lodash-es": "^4.17.0",
    "@types/node": "^24.12.0",
    "@types/tinycolor2": "^1.4.4",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "^21.3.0",
    "eslint": "^10.2.0",
    "execa": "^9.6.0",
    "jsdom": "^29.1.0",
    "lodash-es": "^4.17.0",
    "madge": "^8.0.0",
    "ng-packagr": "^21.2.3",
    "prettier": "^3.8.0",
    "sass": "^1.99.0",
    "semantic-release": "^25.0.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "madge": {
    "detectiveOptions": {
      "ts": {
        "skipTypeImports": true
      }
    }
  }
}
