{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "packages",
  "projects": {
    "demo": {
      "root": "projects/demo",
      "sourceRoot": "projects/demo/src",
      "projectType": "application",
      "prefix": "app",
      "schematics": {
        "@schematics/angular:component": {
          "inlineTemplate": false,
          "style": "scss"
        }
      },
      "architect": {
        "build": {
          "defaultConfiguration": "development",
          "builder": "@angular/build:application",
          "options": {
            "aot": true,
            "outputPath": {
              "base": "dist/demo"
            },
            "index": "projects/demo/src/index.html",
            "tsConfig": "projects/demo/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/demo/public"
              },
              {
                "glob": "**/*",
                "input": "./packages/common/src/assets/",
                "output": "igo2/common/"
              },
              {
                "glob": "**/*",
                "input": "./packages/geo/src/assets/",
                "output": "igo2/geo/"
              },
              {
                "glob": "**/*",
                "input": "./dist/core/assets/",
                "output": "igo2/core/"
              },
              {
                "glob": "*.core.json",
                "input": "./dist/core/locale/",
                "output": "igo2/core/locale"
              },
              {
                "glob": "*.auth.json",
                "input": "./dist/auth/locale/",
                "output": "igo2/auth/locale"
              },
              {
                "glob": "*.common.json",
                "input": "./dist/common/locale/",
                "output": "igo2/common/locale"
              },
              {
                "glob": "*.geo.json",
                "input": "./dist/geo/locale/",
                "output": "igo2/geo/locale"
              },
              {
                "glob": "*.context.json",
                "input": "./dist/context/locale/",
                "output": "igo2/context/locale"
              },
              {
                "glob": "*.integration.json",
                "input": "./dist/integration/locale/",
                "output": "igo2/integration/locale"
              },
              {
                "glob": "**/*",
                "input": "./dist/core/theming/prebuilt-themes",
                "output": "igo2/core/theming/prebuilt-themes"
              }
            ],
            "styles": ["projects/demo/src/styles.scss"],
            "stylePreprocessorOptions": {
              "sass": {
                "silenceDeprecations": ["color-functions"]
              },
              "includePaths": ["node_modules"]
            },
            "scripts": [],
            "allowedCommonJsDependencies": [
              "@turf",
              "canvg",
              "core-js",
              "earcut",
              "file-saver",
              "flexsearch",
              "geojson-rbush",
              "html-entities",
              "html2canvas",
              "jspdf",
              "jspdf-autotable",
              "jszip",
              "moment",
              "nosleep.js",
              "pbf",
              "raf",
              "rbush",
              "rgbcolor",
              "striptags",
              "ts-md5",
              "typy"
            ],
            "browser": "projects/demo/src/main.ts"
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/demo/src/environments/environment.ts",
                  "with": "projects/demo/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "7mb",
                  "maximumError": "8mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ]
            },
            "github": {
              "fileReplacements": [
                {
                  "replace": "projects/demo/src/environments/environment.ts",
                  "with": "projects/demo/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "outputPath": {
                "base": "dist/ghpages"
              },
              "baseHref": "/igo2-lib/",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "7mb",
                  "maximumError": "8mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ]
            },
            "development": {
              "optimization": false,
              "sourceMap": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "host": "127.0.0.1",
            "proxyConfig": "projects/demo/proxy.conf.json",
            "hmr": true,
            "buildTarget": "demo:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "demo:build:production"
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/demo/src/**/*.ts",
              "projects/demo/src/**/*.html"
            ],
            "eslintConfig": "projects/demo/eslint.config.mjs"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "runnerConfig": "projects/demo/vitest.config.ts",
            "browsers": ["chromium"],
            "coverage": true
          }
        }
      }
    },
    "auth": {
      "root": "packages/auth",
      "sourceRoot": "packages/auth",
      "projectType": "library",
      "prefix": "igo",
      "schematics": {
        "@schematics/angular:component": {
          "inlineTemplate": false,
          "style": "scss"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "tsConfig": "packages/auth/tsconfig.lib.json",
            "project": "packages/auth/ng-package.json"
          },
          "configurations": {
            "production": {
              "project": "packages/auth/ng-package.json",
              "tsConfig": "packages/auth/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "packages/auth/tsconfig.lib.json"
            }
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "runnerConfig": "packages/auth/vitest.config.ts",
            "coverage": true
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "packages/auth/**/*.ts",
              "packages/auth/**/*.html"
            ],
            "eslintConfig": "packages/auth/eslint.config.mjs"
          }
        }
      }
    },
